        <mxCell id="pack" value="Pack SHA Block&lt;br&gt;&lt;br&gt;salt 0 or 16 bytes&lt;br&gt;PAN 16 bytes&lt;br&gt;pm0..pm15 words" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontStyle=1" vertex="1" parent="1"><mxGeometry x="945" y="450" width="210" height="120" as="geometry" /></mxCell>
