        <mxCell id="inputs" value="Inputs&lt;br&gt;&lt;br&gt;target hash&lt;br&gt;BIN&lt;br&gt;salt&lt;br&gt;SHA flag" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontStyle=1" vertex="1" parent="1"><mxGeometry x="90" y="150" width="180" height="110" as="geometry" /></mxCell>
        <mxCell id="backend" value="Create Backend&lt;br&gt;&lt;br&gt;Context&lt;br&gt;Accelerator&lt;br&gt;compile kernel probe" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontStyle=1" vertex="1" parent="1"><mxGeometry x="350" y="140" width="210" height="130" as="geometry" /></mxCell>
        <mxCell id="buffers" value="Copy to GPU Buffers&lt;br&gt;&lt;br&gt;dBin&lt;br&gt;dTarget&lt;br&gt;dSalt&lt;br&gt;dFound&lt;br&gt;dFoundCard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#000000;fontStyle=1" vertex="1" parent="1"><mxGeometry x="650" y="135" width="210" height="140" as="geometry" /></mxCell>
        <mxCell id="batch" value="Batch Loop&lt;br&gt;&lt;br&gt;offset += 16M&lt;br&gt;launch kernel&lt;br&gt;synchronize" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontStyle=1" vertex="1" parent="1"><mxGeometry x="950" y="140" width="210" height="130" as="geometry" /></mxCell>
        <mxCell id="read" value="Read Found Marker&lt;br&gt;&lt;br&gt;copy dFound[0]&lt;br&gt;if found, copy card&lt;br&gt;else next batch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#000000;fontStyle=1" vertex="1" parent="1"><mxGeometry x="1250" y="140" width="220" height="130" as="geometry" /></mxCell>
        <mxCell id="note" value="CrackKernel is C# source, but ILGPU compiles it to GPU-native CUDA/OpenCL code before execution." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontStyle=1" vertex="1" parent="1"><mxGeometry x="500" y="325" width="800" height="46" as="geometry" /></mxCell>
        <mxCell id="thread" value="Thread Index&lt;br&gt;&lt;br&gt;candidateIdx =&lt;br&gt;batchOffset + index.X" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontStyle=1" vertex="1" parent="1"><mxGeometry x="90" y="460" width="190" height="100" as="geometry" /></mxCell>
        <mxCell id="pan" value="Build PAN Bytes&lt;br&gt;&lt;br&gt;6 BIN digits&lt;br&gt;9 searched digits&lt;br&gt;candidate 0 = 000000000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontStyle=1" vertex="1" parent="1"><mxGeometry x="365" y="450" width="210" height="120" as="geometry" /></mxCell>
